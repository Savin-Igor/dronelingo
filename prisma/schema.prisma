// Prisma schema for dronelingo.eu.
//
// Multilingual content fields are Json columns shaped {lv, en, ru, ...} with
// `en` as the runtime fallback. See CLAUDE.md for the localization contract.
// Every Question must carry a public-facing sourceRef citation string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  locale        String    @default("lv")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  attempts     Attempt[]
  examResults  ExamResult[]
  certificates Certificate[]
}

// Auth.js (NextAuth v5) required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Topic {
  id        String   @id @default(cuid())
  slug      String   @unique
  ord       Int
  title     Json
  summary   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons   Lesson[]
  questions Question[]

  @@index([ord])
}

model Lesson {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  slug      String
  ord       Int
  title     Json
  bodyMdx   Json
  // Optional structured representation of the 9-block academy lesson anatomy:
  // mission briefing, cinematic scene, core, artefact, scenario, memory anchor,
  // common mistakes, mini quiz, debrief. Authored in MDX; this column is for
  // server-side analytics on which blocks each lesson actually exposes.
  blocks    Json?
  sourceRef String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([topicId, slug])
  @@index([topicId, ord])
}

model Question {
  id                   String   @id @default(cuid())
  externalId           String   @unique
  topicId              String
  topic                Topic    @relation(fields: [topicId], references: [id], onDelete: Restrict)
  stem                 Json
  options              Json
  correctOptionId      String
  explanation          Json
  // Per-distractor rationale: { [optionId]: { lv, en, ru } } — why each wrong
  // option is wrong. Optional during the 3 → 4 option migration.
  distractorRationales Json?
  sourceRef            String
  difficulty           Int?
  // Bloom-style cognitive level: "recall" | "apply" | "analyze".
  cognitiveLevel       String?
  // Scenario flavour: "factual" | "map" | "numeric" | "decision" | "regulatory".
  scenarioType         String?
  // Reference into a lesson + section to route users on repeated failure
  // (e.g. "air-safety/vlos#fpv-observer"). Optional.
  lessonSectionRef     String?
  // Optional image rendered above the question stem (path under /public,
  // e.g. "/questions/meteorology/met-041-cumulonimbus.png").
  imageUrl             String?
  // Localized alt text for imageUrl: { lv, en, ru, ... } — required when
  // imageUrl is set (validated at import time).
  imageAlt             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  attempts Attempt[]

  @@index([topicId])
}

model Attempt {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionId String
  isCorrect        Boolean
  createdAt        DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, questionId])
}

model ExamResult {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int
  total       Int
  passed      Boolean
  perTopic    Json
  durationSec Int
  takenAt     DateTime @default(now())

  @@index([userId, takenAt(sort: Desc)])
}

enum CertificateKind {
  PDF
  CAA_ID
}

model Certificate {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       CertificateKind
  fileUrl    String?
  caaIdRef   String?
  verifiedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId])
}

enum InvoiceStatus {
  PENDING
  PAID
  ACTIVATED
  CANCELLED
}

model InvoiceRequest {
  id          String        @id @default(cuid())
  email       String
  name        String?
  amount      Int
  currency    String        @default("EUR")
  reference   String        @unique
  status      InvoiceStatus @default(PENDING)
  accessToken String?       @unique
  createdAt   DateTime      @default(now())
  paidAt      DateTime?
  activatedAt DateTime?

  @@index([email])
  @@index([status])
}

// Polymorphic search index over lessons, questions, blog, sources, static pages.
// The migration that creates this table also:
//   - CREATE EXTENSION vector;
//   - adds a generated `tsv` tsvector column (GIN-indexed) for lexical FTS;
//   - adds a `vector(384)` `embedding` column (HNSW-indexed) for semantic search.
// Prisma does not natively support tsvector or pgvector columns, so they live
// in raw SQL and are queried via $queryRaw. See docs/search-architecture.md.
model SearchChunk {
  id           String   @id @default(cuid())
  // 'lesson' | 'question' | 'blog' | 'source' | 'static'
  contentType  String
  // topicSlug/lessonSlug, externalId, blogDirSlug, sourceId, staticPage
  contentId    String
  // 'lv' | 'en' | 'ru' (Tier-1 locales only)
  locale       String
  // Slugified heading anchor; empty string "" for anchor-less chunks
  // (questions, top-level pages). Stored as a string instead of nullable
  // so compound unique key (contentType, contentId, locale, anchor) is
  // queryable — Prisma compound `where` requires non-null fields, and
  // Postgres treats multiple NULLs as distinct which breaks dedup.
  anchor       String   @default("")
  // Fully resolved internal URL (per-locale slug already applied for blog)
  url          String
  // Lesson title + section heading, or question stem prefix, etc.
  title        String
  body         String   @db.Text
  // sha256(body + modelVersion) — short-circuit re-embedding of unchanged text
  sourceHash   String
  // Pin so model upgrades trigger a full reindex (e.g. "e5-small-v1")
  modelVersion String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([contentType, contentId, locale, anchor])
  @@index([contentType, locale])
}
