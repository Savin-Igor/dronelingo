// Prisma schema for dronelingo.eu.
//
// Multilingual content fields are Json columns shaped {lv, en, ru, ...} with
// `en` as the runtime fallback. See CLAUDE.md for the localization contract.
// Every Question must carry a sourceRef pointing into docs/knowledge/.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  locale    String   @default("lv")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts     Attempt[]
  examResults  ExamResult[]
  certificates Certificate[]
}

model Topic {
  id        String   @id @default(cuid())
  slug      String   @unique
  ord       Int
  title     Json
  summary   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons   Lesson[]
  questions Question[]

  @@index([ord])
}

model Lesson {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  slug      String
  ord       Int
  title     Json
  bodyMdx   Json
  // Optional structured representation of the 9-block academy lesson anatomy:
  // mission briefing, cinematic scene, core, artefact, scenario, memory anchor,
  // common mistakes, mini quiz, debrief. Authored in MDX; this column is for
  // server-side analytics on which blocks each lesson actually exposes.
  blocks    Json?
  sourceRef String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([topicId, slug])
  @@index([topicId, ord])
}

model Question {
  id                   String   @id @default(cuid())
  externalId           String   @unique
  topicId              String
  topic                Topic    @relation(fields: [topicId], references: [id], onDelete: Restrict)
  stem                 Json
  options              Json
  correctOptionId      String
  explanation          Json
  // Per-distractor rationale: { [optionId]: { lv, en, ru } } — why each wrong
  // option is wrong. Optional during the 3 → 4 option migration.
  distractorRationales Json?
  sourceRef            String
  difficulty           Int?
  // Bloom-style cognitive level: "recall" | "apply" | "analyze".
  cognitiveLevel       String?
  // Scenario flavour: "factual" | "map" | "numeric" | "decision" | "regulatory".
  scenarioType         String?
  // Reference into a lesson + section to route users on repeated failure
  // (e.g. "air-safety/vlos#fpv-observer"). Optional.
  lessonSectionRef     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  attempts Attempt[]

  @@index([topicId])
}

model Attempt {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionId String
  isCorrect        Boolean
  createdAt        DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, questionId])
}

model ExamResult {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int
  total       Int
  passed      Boolean
  perTopic    Json
  durationSec Int
  takenAt     DateTime @default(now())

  @@index([userId, takenAt(sort: Desc)])
}

enum CertificateKind {
  PDF
  CAA_ID
}

model Certificate {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       CertificateKind
  fileUrl    String?
  caaIdRef   String?
  verifiedAt DateTime?
  paidAt     DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([userId])
}
