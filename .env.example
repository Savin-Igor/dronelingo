# ── Local dev ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
# For production: managed by .github/workflows/deploy.yml — never commit real values.

# Database
# Local dev:  postgresql://postgres:postgres@localhost:5434/dronelingo
# Production: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/dronelingo
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/dronelingo"

POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-strong-password-in-production"

# NextAuth v5 (Auth.js)
AUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-in-production-min-32-chars-xxxxxx"
# AUTH_TRUST_HOST=true  # required in prod when running behind a reverse proxy

# Email (magic link + transactional)
# Local dev: Mailhog (docker-compose.dev.yml) — no auth, catches all emails.
#   docker compose -f docker-compose.dev.yml up -d mailhog
#   View emails: http://localhost:8026
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1026"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="dronelingo Dev <dev@dronelingo.eu>"
# Production: replace with Resend (or other SMTP)
# EMAIL_SERVER_HOST="smtp.resend.com"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="resend"
# EMAIL_SERVER_PASSWORD="re_..."
# EMAIL_FROM="dronelingo <noreply@dronelingo.eu>"

ADMIN_EMAIL="admin@dronelingo.eu"

# Invoice payment (invoice-by-default mode)
ADMIN_SECRET="change-me-in-dev-min-16-chars"
INVOICE_IBAN="LV00XXXX0000000000000"
INVOICE_BIC="XXXXLV22"
INVOICE_BANK_NAME="SEB Latvia"
INVOICE_BENEFICIARY="Dronelingo SIA"

# Public (NEXT_PUBLIC_*) — exposed to the browser bundle.
# Used by SEO metadata (canonical URLs, sitemap, og:url).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_SITE_URL="https://dronelingo.eu"

# Feature flags
# Set to "true" to enable Stripe payment (when integration is ready).
# Default: false (invoice-based payment).
# NEXT_PUBLIC_STRIPE_ENABLED="false"

# Plausible Analytics (optional). When set, the script is loaded
# only after the visitor has accepted the consent banner.
# Leave empty to disable analytics entirely.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="dronelingo.eu"

# Skip env validation in dev when not all keys are filled yet.
# SKIP_ENV_VALIDATION=true
